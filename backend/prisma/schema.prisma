// This is your Prisma schema file.
// Learn more about it: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  REGULAR_USER
  ADMIN
}

enum NotificationType {
  EXPIRY_WARNING
  ITEM_EXPIRED
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  role         UserRole @default(REGULAR_USER)
  createdAt    DateTime @default(now())

  pantryItems    PantryItem[]
  shoppingLists  ShoppingList[]
  notifications  Notification[]
}

model Category {
  id   String  @id @default(uuid()) @db.Uuid
  name String  @unique @db.VarChar(100)
  icon String? @db.VarChar(50)

  pantryItems PantryItem[]
}

model PantryItem {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  categoryId String?   @db.Uuid
  name       String    @db.VarChar(255)
  quantity   Decimal   @db.Decimal(10, 2)
  unit       String    @db.VarChar(50)
  expiryDate DateTime? @db.Date
  addedAt    DateTime  @default(now())
  notes      String?   @db.Text

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  notifications Notification[]

  @@index([userId])
  @@index([expiryDate])
}

model Recipe {
  id              String  @id @default(uuid()) @db.Uuid
  title           String  @db.VarChar(255)
  description     String? @db.Text
  instructions    String  @db.Text
  servings        Int     @default(2)
  prepTimeMinutes Int     @default(30)

  ingredients   RecipeIngredient[]
  shoppingItems ShoppingItem[]
}

model RecipeIngredient {
  id             String  @id @default(uuid()) @db.Uuid
  recipeId       String  @db.Uuid
  ingredientName String  @db.VarChar(255)
  quantity       Decimal @db.Decimal(10, 2)
  unit           String  @db.VarChar(50)

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model ShoppingList {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  name      String   @db.VarChar(255) @default("My Shopping List")
  createdAt DateTime @default(now())

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ShoppingItem[]

  @@index([userId])
}

model ShoppingItem {
  id             String  @id @default(uuid()) @db.Uuid
  shoppingListId String  @db.Uuid
  recipeId       String? @db.Uuid
  name           String  @db.VarChar(255)
  quantity       Decimal @db.Decimal(10, 2)
  unit           String  @db.VarChar(50)
  isPurchased    Boolean @default(false)

  shoppingList ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  recipe       Recipe?      @relation(fields: [recipeId], references: [id], onDelete: SetNull)
}

model Notification {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @db.Uuid
  pantryItemId String?          @db.Uuid
  type         NotificationType
  message      String           @db.Text
  isRead       Boolean          @default(false)
  createdAt    DateTime         @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pantryItem PantryItem? @relation(fields: [pantryItemId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
}
